{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "BlankFX Docs",
  "colors": {
    "primary": "#4B9EFF",
    "light": "#4B9EFF",
    "dark": "#2f7ddd"
  },
  "font": {
    "headings": {
      "family": "DM Sans"
    },
    "body": {
      "family": "DM Sans"
    }
  },
  "favicon": "https://cdn.jsdelivr.net/gh/benjiusi/blankfx-docs@main/favicon.png",
  "logo": {
    "light": "https://cdn.jsdelivr.net/gh/benjiusi/blankfx-docs@main/logo/light.png",
    "dark": "https://cdn.jsdelivr.net/gh/benjiusi/blankfx-docs@main/logo/dark.png"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "introduction",
              "getting-started"
            ]
          },
          {
            "group": "Using BlankFX",
            "pages": [
              "swaps",
              "earn",
              "fees"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "contracts",
              "tokens",
              "faq"
            ]
          },
          {
            "group": "Compliance",
            "pages": [
              "compliance"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/benjiusi/blankfx",
          "icon": "github"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Marketing",
        "href": "https://blankfx.org"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Launch App",
      "href": "https://app.blankfx.org"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/benjiusi/blankfx"
    }
  }
}
